# Backend Production Environment Configuration

# Server Configuration
NODE_ENV=production
APP_ENV=demo
PORT=5000

# Database Configuration
DATABASE_URL=postgresql://user:password@host:5432/society_db
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=your_password_here
DB_NAME=society_db

# JWT Configuration
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
JWT_EXPIRES_IN=7d

# Payment Gateway (Razorpay)
PAYMENT_MODE=test
RAZORPAY_KEY_ID=rzp_test_xxxxx
RAZORPAY_KEY_SECRET=your_secret_here
RAZORPAY_WEBHOOK_SECRET=your_webhook_secret

# Email Configuration
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_app_password
EMAIL_FROM=Society Management <no-reply@yourdomain.com>

# OTP Configuration
OTP_MODE=demo
# demo = console logs only (no real SMS/Email)
# production = real SMS/Email delivery

# Demo Mode Safety Switch (IMPORTANT)
DEMO_MODE=true
# When true: No real SMS, No real emails, No destructive actions

# Authentication Configuration
AUTH_MODE=open
# Options: open, admin_only, domain_restricted, invitation_only
ALLOWED_EMAIL_DOMAINS=gmail.com,yahoo.com

# Frontend URLs (for CORS and email links)
FRONTEND_URL=https://admin-demo.yourdomain.com
MOBILE_APP_URL=myapp://

# CCTV Configuration (optional)
CCTV_PUBLIC_STREAM_BASE=https://your-stream-server.example.com/hls

# File Upload Configuration
MAX_FILE_SIZE=10485760
# 10MB in bytes

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
# 15 minutes in milliseconds
RATE_LIMIT_MAX_REQUESTS=100

# Socket.IO Configuration (optional)
# SOCKET_PORT=5001
# SOCKET_CORS_ORIGIN=https://admin-demo.yourdomain.com
