# Mobile App Environment Configuration

# API Base URL (Change this to your backend URL)
EXPO_PUBLIC_API_BASE_URL=https://api-demo.yourdomain.com
EXPO_PUBLIC_APP_ENV=demo

# Optional: Razorpay for in-app payments
# EXPO_PUBLIC_RAZORPAY_KEY=rzp_live_xxxxx

# Optional: Google Maps API (if using maps)
# EXPO_PUBLIC_GOOGLE_MAPS_KEY=your_key_here

# Optional: Socket.IO URL for real-time features
# EXPO_PUBLIC_SOCKET_URL=https://socket-demo.yourdomain.com

# Instructions:
# 1. Copy this to .env (already done)
# 2. Update EXPO_PUBLIC_API_BASE_URL with your backend server URL
# 3. For local development, use: http://YOUR_LOCAL_IP:5000/api
#    Example: http://192.168.1.51:5000/api
# 4. For production, use: https://api.yourdomain.com/api
