# Admin Web Environment Configuration Template
# IMPORTANT: All browser-accessible variables MUST start with NEXT_PUBLIC_

# API Configuration
NEXT_PUBLIC_API_BASE_URL=https://api-demo.yourdomain.com
NEXT_PUBLIC_APP_ENV=production

# Optional: Socket.IO (if used)
# NEXT_PUBLIC_SOCKET_URL=https://socket-demo.yourdomain.com

# Optional: File Upload endpoint
# NEXT_PUBLIC_UPLOAD_URL=https://api-demo.yourdomain.com/uploads

# Optional: Razorpay (if payments in web)
# NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_live_xxxxx

# Instructions:
# 1. Copy this file to .env.production
# 2. Replace the values with your actual production URLs
# 3. Never commit .env.production to git (it's gitignored)
